  return {...DEFAULT_STATE};
})();

function save() { try { localStorage.setItem(STORAGE_KEY,JSON.stringify(S)); } catch{} }

const fUSD = v => `US$ ${Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}`;
const fBRL = v => `R$ ${Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}`;
const fCLP = v => `$ ${Math.round(Number(v)).toLocaleString('pt-BR')} CLP`;

function toUSD(amount, currency) {
  const n = Number(amount);
  if (currency==='USD') return n;
  if (currency==='BRL') return n / S.usdRate;
  if (currency==='CLP') return (n * S.clpRate) / S.usdRate;
  return n;
}

function totals() {
  const spent = S.expenses.reduce((s,e)=>s+e.usd,0);
  const left  = S.nomadUSD - spent;
  const pct   = Math.min((spent/(S.nomadUSD||1))*100,100);
  return {spent,left,pct};
}

function renderHeader() {
  const {spent,left,pct} = totals();
  const color = pct>90?'#FF5555':pct>70?'#FFAA00':'#4FE89B';
  const el = id => document.getElementById(id);
  el('hd-left-usd').textContent = fUSD(Math.max(left,0));
  el('hd-left-usd').style.color = left>=0?'#4FE89B':'#FF5555';
  el('hd-spent-usd').textContent = fUSD(spent);
  el('hd-total-usd').textContent = 'de '+fUSD(S.nomadUSD);
  el('hd-bar').style.width = pct+'%';
  el('hd-bar').style.background = color;
  el('hd-pct').textContent = pct.toFixed(1)+'% usado';
  const se = el('hd-saldo');
  if (left>=0) { se.textContent='Saldo: '+fUSD(left); se.style.color='#4FE89B'; }
  else         { se.textContent='Excedeu: '+fUSD(Math.abs(left)); se.style.color='#FF5555'; }
  const lb = Math.max(left,0)*S.usdRate, lc = lb/S.clpRate;
  el('hd-brl').textContent = fBRL(lb);
  el('hd-brl-gasto').textContent = 'gasto: '+fBRL(spent*S.usdRate);
  el('hd-clp').textContent = fCLP(lc);
  el('hd-clp-gasto').textContent = 'gasto: '+fCLP(spent*S.usdRate/S.clpRate);
}

function renderCategories() {
  const list = document.getElementById('cat-list');
  list.innerHTML = '';
  S.categories.forEach(cat => {
    const spent = S.expenses.filter(e=>e.category===cat.category).reduce((s,e)=>s+e.usd,0);
    const p = cat.budgeted>0 ? Math.min((spent/cat.budgeted)*100,100) : 0;
    const bar = cat.budgeted>0
      ? `<div style="background:#1E2640;border-radius:99px;height:4px;margin-top:7px"><div style="height:100%;width:${p}%;background:${cat.color};border-radius:99px;transition:width .4s"></div></div>` : '';
    const prevSub = cat.budgeted>0
      ? `${fUSD(cat.budgeted)} <span style="color:#5566AA">· ${fBRL(cat.budgeted*S.usdRate)}</span>` : '—';
    list.innerHTML += `
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div style="display:flex;align-items:center;gap:8px">
            <span style="font-size:19px">${cat.icon}</span>
            <div>
              <div style="font-size:13px;font-weight:600;color:#E8EEFF">${cat.category}</div>
              <div style="font-size:10px;color:#5566AA">Prev: ${prevSub}</div>
            </div>
          </div>
          <div style="text-align:right">
            <div style="font-size:14px;font-weight:700;color:${cat.color}">${fUSD(spent)}</div>
            <div style="font-size:10px;color:#5566AA">${fBRL(spent*S.usdRate)}</div>
            ${cat.budgeted>0?`<div style="font-size:9px;color:#445580">${p.toFixed(0)}% do prev.</div>`:''}
          </div>
        </div>${bar}
      </div>`;
  });
}

function renderExpenses() {
  const list=document.getElementById('expense-list'), empty=document.getElementById('expense-empty');
  list.innerHTML='';
  if (S.expenses.length===0) { empty.style.display='block'; return; }
  empty.style.display='none';
  S.expenses.forEach(exp => {
    const cat=S.categories.find(c=>c.category===exp.category)||{};
    const color=cat.color||'#4F6BED', icon=cat.icon||'💸';
    const note=exp.note?`<div style="font-size:10px;color:#445580;font-style:italic">${exp.note}</div>`:'';
    const orig=exp.currency==='USD'?`<div style="font-size:9px;color:#445580">${fUSD(exp.amount)}</div>`
              :exp.currency==='CLP'?`<div style="font-size:9px;color:#445580">${fCLP(exp.amount)}</div>`:'';
    list.innerHTML+=`
      <div class="expense-item" style="border-left:3px solid ${color}">
        <span style="font-size:20px;flex-shrink:0">${icon}</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:600;color:#E8EEFF;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${exp.desc}</div>
          <div style="font-size:10px;color:#5566AA">${exp.category} · ${exp.date}/07</div>${note}
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-size:14px;font-weight:800;color:${color}">${fUSD(exp.usd)}</div>
          <div style="font-size:10px;color:#5566AA">${fBRL(exp.usd*S.usdRate)}</div>
          <div style="font-size:9px;color:#3A4470">${fCLP(exp.usd*S.usdRate/S.clpRate)}</div>${orig}
        </div>
        <button class="del-exp" onclick="deleteExpense(${exp.id})">×</button>
      </div>`;
  });
}

function deleteExpense(id) { S.expenses=S.expenses.filter(e=>e.id!==id); save(); renderAll(); showToast('Removido 🗑️'); }

function renderItin() {
  const list=document.getElementById('itin-list'); list.innerHTML='';
  S.itinerary.forEach(day=>{
    const key=day.date.slice(4);
    const spent=S.expenses.filter(e=>e.date===key).reduce((s,e)=>s+e.usd,0);
    const spentHtml=spent>0
      ?`<div style="font-size:13px;font-weight:700;color:#4FE89B">${fUSD(spent)}</div><div style="font-size:10px;color:#445580">${fBRL(spent*S.usdRate)}</div>`
      :`<div style="font-size:13px;font-weight:700;color:#2A3355">${fUSD(0)}</div>`;
    const acts=day.activities.map((a,j)=>
      `<div style="font-size:12px;color:#C0CCEE;padding:4px 0;display:flex;align-items:center;gap:7px;${j<day.activities.length-1?'border-bottom:1px solid #1A2240':''}">
        <span style="color:#2A3A60;font-size:9px">●</span> ${a}
       </div>`).join('');
    list.innerHTML+=`
      <div class="itin-day">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
          <div>
            <div style="font-size:13px;font-weight:700;color:#7F9FFF">${day.date}</div>
            <div style="font-size:10px;color:#445580">${day.label}</div>
          </div>
          <div style="text-align:right">${spentHtml}</div>
        </div>${acts}
      </div>`;
  });
}

function renderTips() {
  const list=document.getElementById('tips-list'); list.innerHTML='';
  S.tips.forEach(tip=>{
    list.innerHTML+=`
      <div class="tip-card">
        <div style="display:flex;align-items:center;gap:9px;margin-bottom:7px">
          <span style="font-size:22px">${tip.icon}</span>
          <div style="font-size:13px;font-weight:700;color:#E8EEFF">${tip.title}</div>
        </div>
        <div style="font-size:12px;line-height:1.68;color:#9AAABB">${tip.text}</div>
      </div>`;
  });
}

function renderConfig() {
  document.getElementById('cfg-nomad').value=S.nomadUSD;
  document.getElementById('cfg-usd').value=S.usdRate;
  document.getElementById('cfg-clp').value=S.clpRate;
  cfgConvert();
  const {spent,left}=totals();
  document.getElementById('cfg-summary').innerHTML=`
    <div class="sum-row"><span class="sum-label">Nomad disponível</span><div><div class="sum-val">${fUSD(Math.max(left,0))}</div><div class="sum-sub">${fBRL(Math.max(left,0)*S.usdRate)}</div></div></div>
    <div class="sum-row"><span class="sum-label">Total gasto</span><div><div class="sum-val">${fUSD(spent)}</div><div class="sum-sub">${fBRL(spent*S.usdRate)}</div></div></div>
    <div class="sum-row"><span class="sum-label">Taxa: US$ 1 =</span><div class="sum-val">${fBRL(S.usdRate)}</div></div>
    <div class="sum-row" style="border:none"><span class="sum-label">Taxa: $ 1 CLP =</span><div class="sum-val">R$ ${S.clpRate}</div></div>`;
}

function cfgConvert() {
  const n=Number(document.getElementById('cfg-nomad').value)||0;
  const u=Number(document.getElementById('cfg-usd').value)||S.usdRate;
  const c=Number(document.getElementById('cfg-clp').value)||S.clpRate;
  document.getElementById('cfg-nomad-brl').textContent=fBRL(n*u);
  document.getElementById('cfg-nomad-clp').textContent=fCLP(n*u/c);
}

function saveConfig() {
  S.nomadUSD=Number(document.getElementById('cfg-nomad').value)||S.nomadUSD;
  S.usdRate=Number(document.getElementById('cfg-usd').value)||S.usdRate;
  S.clpRate=Number(document.getElementById('cfg-clp').value)||S.clpRate;
  save(); renderAll(); showToast('Configurações salvas ✅');
}

function populateForm() {
  const cs=document.getElementById('f-category'); cs.innerHTML='';
  S.categories.forEach(c=>{const o=document.createElement('option');o.value=c.category;o.textContent=c.category;cs.appendChild(o);});
  const ds=document.getElementById('f-date'); ds.innerHTML='';
  S.itinerary.forEach(d=>{const o=document.createElement('option');o.value=d.date.slice(4);o.textContent=d.date;ds.appendChild(o);});
  if(ds.options.length>1) ds.selectedIndex=1;
}

function toggleForm() {
  const form=document.getElementById('expense-form'), btn=document.getElementById('add-btn');
  const open=form.style.display==='block';
  form.style.display=open?'none':'block';
  btn.innerHTML=open?'<span style="font-size:20px">+</span> Adicionar Gasto':'<span style="font-size:20px">−</span> Cancelar';
  btn.style.background=open?'linear-gradient(135deg,#4F6BED,#9B59B6)':'#1E2640';
  if(!open){['f-desc','f-amount','f-note'].forEach(id=>document.getElementById(id).value='');document.getElementById('expense-preview').style.display='none';}
}

function updatePreview() {
  const amount=Number(document.getElementById('f-amount').value);
  const currency=document.getElementById('f-currency').value;
  const prev=document.getElementById('expense-preview');
  if(!amount){prev.style.display='none';return;}
  const usd=toUSD(amount,currency);
  document.getElementById('prev-usd').textContent=fUSD(usd);
  document.getElementById('prev-brl-clp').textContent=fBRL(usd*S.usdRate)+' · '+fCLP(usd*S.usdRate/S.clpRate);
  prev.style.display='block';
}

function addExpense() {
  const desc=document.getElementById('f-desc').value.trim();
  const amount=Number(document.getElementById('f-amount').value);
  const currency=document.getElementById('f-currency').value;
  const category=document.getElementById('f-category').value;
  const date=document.getElementById('f-date').value;
  const note=document.getElementById('f-note').value.trim();
  if(!desc||!amount){showToast('Preencha descrição e valor ⚠️');return;}
  S.expenses.unshift({id:Date.now(),desc,amount,currency,category,date,note,usd:toUSD(amount,currency)});
  save();renderAll();toggleForm();showToast('Gasto adicionado! ✅');
}

function clearExpenses() {
  if(!confirm('Apagar todos os gastos? Isso não pode ser desfeito.'))return;
  S.expenses=[];save();renderAll();showToast('Gastos apagados 🗑️');
}

function openSettings() {
  document.getElementById('ms-nomad').value=S.nomadUSD;
  document.getElementById('ms-usd').value=S.usdRate;
  document.getElementById('ms-clp').value=S.clpRate;
  msConvert();
  document.getElementById('modal-settings').classList.add('open');
}
function closeSettings(){document.getElementById('modal-settings').classList.remove('open');}
function saveSettings(){
  S.nomadUSD=Number(document.getElementById('ms-nomad').value)||S.nomadUSD;
  S.usdRate=Number(document.getElementById('ms-usd').value)||S.usdRate;
  S.clpRate=Number(document.getElementById('ms-clp').value)||S.clpRate;
  save();renderAll();closeSettings();showToast('Configurações salvas ✅');
}
function msConvert(){
  const n=Number(document.getElementById('ms-nomad').value)||0;
  const u=Number(document.getElementById('ms-usd').value)||S.usdRate;
  const c=Number(document.getElementById('ms-clp').value)||S.clpRate;
  document.getElementById('ms-preview').textContent=n>0?`= ${fBRL(n*u)} · ${fCLP(n*u/c)}`:'';
}

let itinDraft=[];
function openItin(){itinDraft=JSON.parse(JSON.stringify(S.itinerary));renderItinEdit();document.getElementById('modal-itin').classList.add('open');}
function closeItin(){document.getElementById('modal-itin').classList.remove('open');}
function saveItin(){S.itinerary=JSON.parse(JSON.stringify(itinDraft));save();renderAll();closeItin();showToast('Roteiro atualizado ✅');}

function renderItinEdit() {
  const list=document.getElementById('itin-edit-list'); list.innerHTML='';
  itinDraft.forEach((day,di)=>{
    const acts=day.activities.map((a,ai)=>`
      <div style="display:flex;align-items:center;gap:7px;margin-bottom:6px">
        <div class="act-text">${a}</div>
        <button class="act-del" onclick="removeAct(${di},${ai})">×</button>
      </div>`).join('');
    list.innerHTML+=`
      <div style="margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #1A2240">
        <div style="font-size:12px;font-weight:700;color:#7F9FFF;margin-bottom:8px">${day.date}</div>
        ${acts}
        <div style="display:flex;gap:7px;margin-top:6px">
          <input id="new-act-${di}" class="inp" placeholder="+ Nova atividade..." style="font-size:12px;padding:8px 10px" onkeydown="if(event.key==='Enter')addAct(${di})" />
          <button onclick="addAct(${di})" style="padding:8px 14px;background:#1A2550;border:1px solid #3A4A8A;border-radius:8px;color:#8FA4FF;font-size:16px;cursor:pointer;flex-shrink:0">+</button>
        </div>
      </div>`;
  });
}

function addAct(di){const i=document.getElementById(`new-act-${di}`),v=i.value.trim();if(!v)return;itinDraft[di].activities.push(v);i.value='';renderItinEdit();}
function removeAct(di,ai){itinDraft[di].activities.splice(ai,1);renderItinEdit();}

function setTab(name,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  if(name==='config') renderConfig();
}

let toastTimer;
function showToast(msg){
  const el=document.getElementById('toast');
  el.textContent=msg; el.style.display='block';
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.style.display='none',2500);
}

function renderAll(){renderHeader();renderCategories();renderExpenses();renderItin();renderTips();}

populateForm();
renderAll();
</script>

</body>
</html>
