/* ── inputs & selects ── */
input, select, button { font-family: 'Outfit', sans-serif; }
.inp {
  background: #0B0F1A; border: 1px solid rgba(255,255,255,0.15); border-radius: 10px;
  padding: 11px 12px; color: #fff; font-size: 14px; width: 100%;
}
.inp::placeholder { color: rgba(255,255,255,0.3); }
.inp:focus { outline: none; border-color: rgba(79,107,237,0.6); }
select.inp { font-size: 13px; cursor: pointer; }
input[type=number] { -moz-appearance: textfield; }
input[type=number]::-webkit-outer-spin-button,
input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }

/* ── header ── */
#header {
  background: linear-gradient(135deg, #1a2a6c 0%, #b21f1f 52%, #fdbb2d 100%);
  padding: 26px 20px 20px; position: relative; overflow: hidden;
}
#header::before {
  content: ''; position: absolute; top: -40px; right: -40px;
  width: 160px; height: 160px; border-radius: 50%; background: rgba(255,255,255,0.04);
}
#header::after {
  content: ''; position: absolute; bottom: -20px; left: -20px;
  width: 100px; height: 100px; border-radius: 50%; background: rgba(255,255,255,0.04);
}

/* ── bottom nav ── */
#bottom-nav {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 480px; background: #0D1120;
  border-top: 1px solid rgba(255,255,255,0.06); display: flex; z-index: 100;
}
.nav-btn {
  flex: 1; padding: 11px 0 13px; background: none; border: none; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  opacity: 0.36; transition: opacity .2s; color: #888;
}
.nav-btn.active { opacity: 1; color: #7F9FFF; }
.nav-btn span:first-child { font-size: 17px; }
.nav-btn span:last-child  { font-size: 9px; font-weight: 400; }
.nav-btn.active span:last-child { font-weight: 700; color: #7F9FFF; }

/* ── tabs ── */
.tab { display: none; padding: 14px 14px 0; }
.tab.active { display: block; }

/* ── cards ── */
.card {
  background: #141929; border-radius: 13px; padding: 11px 14px; margin-bottom: 9px;
}
.card-label { font-size: 10px; opacity: 0.55; letter-spacing: 1px; margin-bottom: 4px; text-transform: uppercase; }

/* ── progress bar ── */
.progress-wrap { background: rgba(255,255,255,0.13); border-radius: 99px; overflow: hidden; }
.progress-bar  { height: 100%; border-radius: 99px; transition: width .5s; }

/* ── nomad card ── */
#nomad-card {
  background: rgba(0,0,0,0.35); border-radius: 14px; padding: 16px 18px; margin-top: 16px;
}

/* ── section title ── */
.section-title {
  font-size: 11px; font-weight: 700; opacity: 0.45; letter-spacing: 1.5px;
  text-transform: uppercase; margin-bottom: 9px;
}

/* ── modals ── */
.modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.72);
  z-index: 200; align-items: flex-end; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-sheet {
  background: #141929; border-radius: 18px 18px 0 0; padding: 22px;
  width: 100%; max-width: 480px; max-height: 85vh; overflow-y: auto;
}
.modal-title { font-size: 15px; font-weight: 800; margin-bottom: 18px; }

/* ── btn primary ── */
.btn-primary {
  background: linear-gradient(135deg, #4F6BED, #9B59B6);
  border: none; border-radius: 10px; color: #fff;
  font-size: 14px; font-weight: 700; cursor: pointer; padding: 12px;
  width: 100%; font-family: 'Outfit', sans-serif;
}
.btn-secondary {
  background: rgba(255,255,255,0.07); border: none; border-radius: 10px;
  color: #fff; font-size: 14px; cursor: pointer; padding: 12px;
  font-family: 'Outfit', sans-serif;
}

/* ── toast ── */
#toast {
  display: none; position: fixed; top: 18px; left: 50%; transform: translateX(-50%);
  background: #4FE89B; color: #000; padding: 10px 22px; border-radius: 99px;
  font-size: 13px; font-weight: 700; z-index: 999;
  box-shadow: 0 4px 24px rgba(79,232,155,0.4); white-space: nowrap;
}

/* ── expense item ── */
.expense-item {
  background: #141929; border-radius: 13px; padding: 11px 14px;
  margin-bottom: 9px; display: flex; align-items: center; gap: 11px;
}

/* ── decolar card ── */
#decolar-card {
  background: linear-gradient(135deg, rgba(79,107,237,.13), rgba(155,89,182,.13));
  border-radius: 14px; padding: 13px 15px; margin-bottom: 13px;
  border: 1px solid rgba(79,107,237,.28);
}

/* ── tip card ── */
.tip-card {
  background: #141929; border-radius: 13px; padding: 14px 15px;
  margin-bottom: 11px; border-left: 3px solid rgba(253,187,45,0.55);
}

/* ── itinerary day ── */
.itin-day {
  background: #141929; border-radius: 13px; padding: 13px 15px;
  margin-bottom: 11px; border-top: 2px solid rgba(79,107,237,0.22);
}

/* ── preview conversion ── */
#expense-preview {
  background: rgba(79,232,155,0.08); border-radius: 8px; padding: 8px 11px;
  margin: 8px 0 10px; font-size: 12px; color: #4FE89B; line-height: 1.6;
  display: none;
}

/* ── add form ── */
#expense-form {
  background: #141929; border-radius: 15px; padding: 16px; margin-bottom: 14px;
  border: 1px solid rgba(255,255,255,0.07); display: none;
}

.row2 { display: flex; gap: 8px; margin-bottom: 10px; }
.row2 > div { flex: 1; }
.row2 > div:first-child { flex: 2; }

.sub-conv {
  display: flex; gap: 8px; margin-top: 8px;
}
.sub-conv > div {
  flex: 1; background: rgba(255,255,255,0.05); border-radius: 8px;
  padding: 7px 10px; font-size: 11px; opacity: 0.7;
}
