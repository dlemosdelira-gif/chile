    {/* ── DICAS ── */}
    {tab === "dicas" && (
      <div>
        <div style={{ fontSize:11, fontWeight:700, opacity:0.45, marginBottom:12, letterSpacing:1.5, textTransform:"uppercase" }}>Dicas para a Viagem 🇨🇱</div>
