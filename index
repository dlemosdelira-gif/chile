input, select, button { font-family: 'Outfit', sans-serif; color: #F0F4FF; }

.inp {
  background: #0D1323;
  border: 1px solid #2A3355;
  border-radius: 10px;
  padding: 11px 12px;
  color: #F0F4FF;
  font-size: 14px;
  width: 100%;
}
.inp::placeholder { color: #4A5580; }
.inp:focus { outline: none; border-color: #4F6BED; }
select.inp { font-size: 13px; cursor: pointer; }
input[type=number] { -moz-appearance: textfield; }
input[type=number]::-webkit-outer-spin-button,
input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }

/* header */
#header {
  background: linear-gradient(135deg, #1a2a6c 0%, #b21f1f 52%, #fdbb2d 100%);
  padding: 26px 20px 20px;
  position: relative;
  overflow: hidden;
}

/* bottom nav */
#bottom-nav {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 480px;
  background: #0D1120;
  border-top: 1px solid #1E2640;
  display: flex; z-index: 100;
}
.nav-btn {
  flex: 1; padding: 11px 0 13px; background: none; border: none; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  opacity: 0.38; transition: opacity .2s;
}
.nav-btn.active { opacity: 1; }
.nav-btn span:first-child { font-size: 17px; }
.nav-btn span:last-child  { font-size: 9px; font-weight: 400; color: #8898CC; }
.nav-btn.active span:last-child { font-weight: 700; color: #7F9FFF; }

/* tabs */
.tab { display: none; padding: 14px 14px 0; }
.tab.active { display: block; }

/* cards */
.card { background: #141929; border-radius: 13px; padding: 11px 14px; margin-bottom: 9px; }
.card-label { font-size: 10px; color: #8898CC; letter-spacing: 1px; margin-bottom: 5px; text-transform: uppercase; }

/* progress bar */
.progress-wrap { background: #1E2A44; border-radius: 99px; overflow: hidden; }
.progress-bar  { height: 100%; border-radius: 99px; transition: width .5s; }

/* nomad card inside header */
#nomad-card { background: #0D1630; border-radius: 14px; padding: 16px 18px; margin-top: 14px; }

/* sub display cards (BRL/CLP) */
.sub-display { background: #17203A; border-radius: 9px; padding: 8px 10px; flex: 1; }
.sub-display .label { font-size: 9px; color: #6677AA; letter-spacing: 1px; margin-bottom: 2px; }
.sub-display .value { font-size: 14px; font-weight: 700; color: #E8EEFF; }
.sub-display .sub   { font-size: 9px; color: #4A5A80; margin-top: 1px; }

/* section title */
.section-title { font-size: 11px; font-weight: 700; color: #6677AA; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 9px; }

/* modals */
.modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.78);
  z-index: 200; align-items: flex-end; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-sheet {
  background: #141929; border-radius: 18px 18px 0 0; padding: 22px;
  width: 100%; max-width: 480px; max-height: 85vh; overflow-y: auto;
}
.modal-title { font-size: 15px; font-weight: 800; color: #F0F4FF; margin-bottom: 18px; }

/* buttons */
.btn-primary {
  background: linear-gradient(135deg, #4F6BED, #9B59B6);
  border: none; border-radius: 10px; color: #fff;
  font-size: 14px; font-weight: 700; cursor: pointer; padding: 12px; width: 100%;
}
.btn-secondary {
  background: #1E2640; border: none; border-radius: 10px;
  color: #C8D0EE; font-size: 14px; cursor: pointer; padding: 12px; width: 100%;
}

/* toast */
#toast {
  display: none; position: fixed; top: 18px; left: 50%; transform: translateX(-50%);
  background: #4FE89B; color: #000; padding: 10px 22px; border-radius: 99px;
  font-size: 13px; font-weight: 700; z-index: 999;
  box-shadow: 0 4px 24px #1a6645; white-space: nowrap;
}

/* expense item */
.expense-item {
  background: #141929; border-radius: 13px; padding: 11px 14px;
  margin-bottom: 9px; display: flex; align-items: center; gap: 11px;
}

/* decolar card */
#decolar-card {
  background: #16204A;
  border-radius: 14px; padding: 13px 15px; margin-bottom: 13px;
  border: 1px solid #3A4A8A;
}

/* tip card */
.tip-card {
  background: #141929; border-radius: 13px; padding: 14px 15px;
  margin-bottom: 11px; border-left: 3px solid #C89820;
}

/* itinerary day */
.itin-day {
  background: #141929; border-radius: 13px; padding: 13px 15px;
  margin-bottom: 11px; border-top: 2px solid #2A3A6A;
}

/* expense preview */
#expense-preview {
  background: #0D2218; border-radius: 8px; padding: 8px 11px;
  margin: 8px 0 10px; font-size: 12px; color: #4FE89B; line-height: 1.6;
  display: none; border: 1px solid #1A4432;
}

/* add expense form */
#expense-form {
  background: #141929; border-radius: 15px; padding: 16px; margin-bottom: 14px;
  border: 1px solid #1E2640; display: none;
}

.row2 { display: flex; gap: 8px; margin-bottom: 10px; }
.row2 > div { flex: 1; }
.row2 > div:first-child { flex: 2; }

.sub-conv { display: flex; gap: 8px; margin-top: 8px; }
.sub-conv > div {
  flex: 1; background: #0D1323; border-radius: 8px;
  padding: 7px 10px; font-size: 11px; color: #A0AACF; border: 1px solid #1E2640;
}

/* config summary row */
.sum-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 0; border-bottom: 1px solid #1E2640;
}
.sum-row:last-child { border-bottom: none; }
.sum-label { font-size: 12px; color: #7788AA; }
.sum-val   { font-size: 13px; font-weight: 700; color: #E8EEFF; text-align: right; }
.sum-sub   { font-size: 9px; color: #4A5A80; }

/* itin edit */
.act-text {
  flex: 1; font-size: 12px; background: #0D1323; border-radius: 8px;
  padding: 7px 10px; color: #C8D4F4; border: 1px solid #1E2640;
}
.act-del {
  background: #2A1018; border: 1px solid #5A2028; border-radius: 7px;
  color: #FF6677; font-size: 14px; cursor: pointer; padding: 6px 10px; flex-shrink: 0;
}

/* delete expense button */
.del-exp {
  background: none; border: none; color: #FF5566; font-size: 20px;
  cursor: pointer; padding-left: 4px; flex-shrink: 0; line-height: 1;
}

/* expense empty */
#expense-empty { text-align: center; color: #4A5580; padding: 40px; display: none; }
