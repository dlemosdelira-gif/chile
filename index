            <div style={{ display:"flex", alignItems:"center", gap:9, marginBottom:7 }}>
              <span style={{ fontSize:22 }}>{tip.icon}</span>
              <div style={{ fontSize:13, fontWeight:700 }}>{tip.title}</div>
            </div>
            <div style={{ fontSize:12, lineHeight:1.68, opacity:0.7 }}>{tip.text}</div>
          </div>
        ))}
      </div>
    )}

    {/* ── CONFIG ── */}
    {tab === "config" && (
      <div>
        <div style={{ fontSize:11, fontWeight:700, opacity:0.45, marginBottom:12, letterSpacing:1.5, textTransform:"uppercase" }}>Configurações</div>

        <div style={{ background:"#141929", borderRadius:13, padding:16, marginBottom:11 }}>
          <div style={{ fontSize:13, fontWeight:700, marginBottom:13 }}>💳 Saldo Nomad — Orçamento Total (USD)</div>
          <NumInput value={nomadUSD} onChange={v=>update({nomadUSD:Number(v)})} step="1" placeholder="1000" />
          <div style={{ display:"flex", gap:8, marginTop:8 }}>
            <div style={{ flex:1, background:"rgba(255,255,255,0.05)", borderRadius:8, padding:"7px 10px", fontSize:11, opacity:0.7 }}>
              {fBRL(nomadUSD*usdRate)}
