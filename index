/* ── formatadores ── */
const fUSD = (v) => `US$ ${Number(v).toLocaleString("pt-BR", { minimumFractionDigits: 2 })}`;
const fBRL = (v) => `R$ ${Number(v).toLocaleString("pt-BR", { minimumFractionDigits: 2 })}`;
const fCLP = (v) => `$ ${Math.round(Number(v)).toLocaleString("pt-BR")} CLP`;

/* ── input numérico com teclado numérico mobile ── */
const NumInput = ({ value, onChange, placeholder, step = “0.01”, style }) => (
<input
type=“number” inputMode=“decimal” pattern=”[0-9]*”
step={step} value={value} placeholder={placeholder}
onChange={e => onChange(e.target.value)}
style={{ background: “#0B0F1A”, border: “1px solid rgba(255,255,255,0.15)”, borderRadius: 10,
padding: “11px 12px”, color: “#fff”, fontSize: 15, boxSizing: “border-box”,
width: “100%”, fontFamily: “inherit”, …style }}
/>
);

export default function App() {
const [tab, setTab] = useState(“resumo”);
const [state, setState] = useState(() => {
try {
const s = localStorage.getItem(STORAGE_KEY);
if (s) return { …DEFAULT_STATE, …JSON.parse(s) };
} catch {}
return DEFAULT_STATE;
});

const [showForm,       setShowForm]       = useState(false);
const [form,           setForm]           = useState({ desc: “”, amount: “”, currency: “USD”, category: “Alimentação”, date: “04/07”, note: “” });
const [toast,          setToast]          = useState(””);
const [editSettings,   setEditSettings]   = useState(false);
const [settingsDraft,  setSettingsDraft]  = useState({});
const [editItinerary,  setEditItinerary]  = useState(false);
const [itin,           setItin]           = useState([]);
const [newActivity,    setNewActivity]    = useState({});

const { nomadUSD, usdRate, clpRate, categories, itinerary, expenses, tips } = state;

useEffect(() => {
try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
}, [state]);

const update = (patch) => setState(s => ({ …s, …patch }));
const showToast = (msg) => { setToast(msg); setTimeout(() => setToast(””), 2500); };

/* conversão para USD (moeda-base) */
const toUSD = (amount, currency) => {
const n = Number(amount);
if (currency === “USD”) return n;
if (currency === “BRL”) return n / usdRate;
if (currency === “CLP”) return (n * clpRate) / usdRate;
return n;
};

/* totais — tudo em USD */
const totalSpentUSD = expenses.reduce((s, e) => s + e.usd, 0);
const nomadLeft     = nomadUSD - totalSpentUSD;
const pct           = Math.min((totalSpentUSD / (nomadUSD || 1)) * 100, 100);

/* por categoria (USD) */
const byCategory = categories.map(cat => ({
…cat,
spent: expenses.filter(e => e.category === cat.category).reduce((s, e) => s + e.usd, 0),
}));

/* por dia (USD) */
const byDay = itinerary.map(day => {
const key   = day.date.slice(4);
const spent = expenses.filter(e => e.date === key).reduce((s, e) => s + e.usd, 0);
return { …day, spent, key };
});

/* adicionar gasto */
const addExpense = () => {
if (!form.desc || !form.amount) return;
const usd = toUSD(form.amount, form.currency);
update({ expenses: [{ …form, id: Date.now(), usd, amount: Number(form.amount) }, …expenses] });
setForm({ desc: “”, amount: “”, currency: “USD”, category: “Alimentação”, date: “04/07”, note: “” });
setShowForm(false);
showToast(“Gasto adicionado! ✅”);
};

/* editar settings */
const openSettings = () => { setSettingsDraft({ nomadUSD, usdRate, clpRate }); setEditSettings(true); };
const saveSettings = () => {
update({ nomadUSD: Number(settingsDraft.nomadUSD), usdRate: Number(settingsDraft.usdRate), clpRate: Number(settingsDraft.clpRate) });
setEditSettings(false);
showToast(“Configurações salvas ✅”);
};

/* editar roteiro */
const openItin  = () => { setItin(JSON.parse(JSON.stringify(itinerary))); setNewActivity({}); setEditItinerary(true); };
const saveItin  = () => { update({ itinerary: itin }); setEditItinerary(false); showToast(“Roteiro atualizado ✅”); };
const addAct    = (di) => {
const v = (newActivity[di] || “”).trim(); if (!v) return;
setItin(itin.map((d, i) => i === di ? { …d, activities: […d.activities, v] } : d));
setNewActivity(p => ({ …p, [di]: “” }));
};
const removeAct = (di, ai) =>
setItin(itin.map((d, i) => i === di ? { …d, activities: d.activities.filter((_, j) => j !== ai) } : d));

const tabs = [
{ id: “resumo”,  label: “Resumo”,  icon: “📊” },
{ id: “gastos”,  label: “Gastos”,  icon: “💰” },
{ id: “roteiro”, label: “Roteiro”, icon: “🗓️” },
{ id: “dicas”,   label: “Dicas”,   icon: “💡” },
{ id: “config”,  label: “Config”,  icon: “⚙️” },
];

const inp = { background: “#0B0F1A”, border: “1px solid rgba(255,255,255,0.15)”, borderRadius: 10,
padding: “11px 12px”, color: “#fff”, fontSize: 14, boxSizing: “border-box”, width: “100%”, fontFamily: “inherit” };
const sel = { …inp, fontSize: 13 };

/* preview de conversão ao digitar o gasto */
const previewUSD = form.amount > 0 ? toUSD(form.amount, form.currency) : null;

return (
<div style={{ fontFamily: “‘Outfit’, sans-serif”, background: “#0B0F1A”, minHeight: “100vh”,
color: “#F0F4FF”, maxWidth: 480, margin: “0 auto”, position: “relative”, paddingBottom: 82 }}>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet" />

