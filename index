            <div style={{ flex:1, background:"rgba(255,255,255,0.05)", borderRadius:8, padding:"7px 10px", fontSize:11, opacity:0.7 }}>
              {fCLP(nomadUSD*usdRate/clpRate)}
            </div>
          </div>
        </div>

        <div style={{ background:"#141929", borderRadius:13, padding:16, marginBottom:11 }}>
          <div style={{ fontSize:13, fontWeight:700, marginBottom:13 }}>💱 Taxas de Câmbio</div>
          <div style={{ marginBottom:11 }}>
            <div style={{ fontSize:10, opacity:0.55, marginBottom:4, letterSpacing:1 }}>🇺🇸 US$ 1 em Reais (R$)</div>
            <NumInput value={usdRate} onChange={v=>update({usdRate:Number(v)})} step="0.01" />
          </div>
          <div>
            <div style={{ fontSize:10, opacity:0.55, marginBottom:4, letterSpacing:1 }}>🇨🇱 $ 1 CLP em Reais (R$)</div>
            <NumInput value={clpRate} onChange={v=>update({clpRate:Number(v)})} step="0.001" />
          </div>
        </div>

        <div style={{ background:"#141929", borderRadius:13, padding:16, marginBottom:16 }}>
          <div style={{ fontSize:13, fontWeight:700, marginBottom:10 }}>📊 Resumo</div>
          {[
            { label:"Nomad disponível", v: fUSD(Math.max(nomadLeft,0)), sub: fBRL(Math.max(nomadLeft,0)*usdRate), alert:false },
            { label:"Total gasto",      v: fUSD(totalSpentUSD),         sub: fBRL(totalSpentUSD*usdRate),         alert:false },
            { label:"Taxa: US$ 1 =",    v: fBRL(usdRate),               sub:"",                                   alert:false },
            { label:"Taxa: $ 1 CLP =",  v:`R$ ${clpRate}`,              sub:"",                                   alert:false },
          ].map((r,i)=>(
            <div key={i} style={{ display:"flex", justifyContent:"space-between", alignItems:"center", padding:"8px 0", borderBottom:i<3?"1px solid rgba(255,255,255,0.05)":"none" }}>
              <div style={{ fontSize:12, opacity:0.55 }}>{r.label}</div>
              <div style={{ textAlign:"right" }}>
                <div style={{ fontSize:13, fontWeight:700 }}>{r.v}</div>
                {r.sub && <div style={{ fontSize:9, opacity:0.38 }}>{r.sub}</div>}
              </div>
            </div>
          ))}
        </div>

        <button onClick={()=>{ if(window.confirm("Apagar todos os gastos lançados?")) { update({expenses:[]}); showToast("Gastos apagados 🗑️"); } }}
          style={{ width:"100%", padding:12, background:"rgba(255,68,68,0.1)", border:"1px solid rgba(255,68,68,0.28)",
            borderRadius:11, color:"#FF7777", fontSize:13, cursor:"pointer", fontFamily:"inherit" }}>
          🗑️ Apagar todos os gastos
        </button>
      </div>
    )}
  </div>

  {/* ══ MODAL: Editar Config (header) ══ */}
  {editSettings && (
    <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.72)", zIndex:200,
      display:"flex", alignItems:"flex-end", justifyContent:"center" }}
      onClick={e=>e.target===e.currentTarget&&setEditSettings(false)}>
      <div style={{ background:"#141929", borderRadius:"18px 18px 0 0", padding:22,
        width:"100%", maxWidth:480, maxHeight:"80vh", overflowY:"auto" }}>
        <div style={{ fontSize:15, fontWeight:800, marginBottom:18 }}>⚙️ Editar Configurações</div>

        <div style={{ marginBottom:13 }}>
          <div style={{ fontSize:10, opacity:0.55, marginBottom:4, letterSpacing:1 }}>💳 Saldo Nomad — Orçamento Total (USD)</div>
          <NumInput value={settingsDraft.nomadUSD} onChange={v=>setSettingsDraft(p=>({...p,nomadUSD:v}))} step="1" />
          {settingsDraft.nomadUSD > 0 && (
            <div style={{ fontSize:11, opacity:0.45, marginTop:5 }}>
              = {fBRL(settingsDraft.nomadUSD * (settingsDraft.usdRate||usdRate))} · {fCLP(settingsDraft.nomadUSD*(settingsDraft.usdRate||usdRate)/clpRate)}
            </div>
          )}
        </div>
        <div style={{ marginBottom:13 }}>
          <div style={{ fontSize:10, opacity:0.55, marginBottom:4, letterSpacing:1 }}>🇺🇸 US$ 1 em Reais (R$)</div>
          <NumInput value={settingsDraft.usdRate} onChange={v=>setSettingsDraft(p=>({...p,usdRate:v}))} step="0.01" />
        </div>
        <div style={{ marginBottom:18 }}>
          <div style={{ fontSize:10, opacity:0.55, marginBottom:4, letterSpacing:1 }}>🇨🇱 $ 1 CLP em Reais (R$)</div>
          <NumInput value={settingsDraft.clpRate} onChange={v=>setSettingsDraft(p=>({...p,clpRate:v}))} step="0.001" />
        </div>

        <div style={{ display:"flex", gap:10 }}>
          <button onClick={()=>setEditSettings(false)} style={{ flex:1, padding:12, background:"rgba(255,255,255,0.07)",
            border:"none", borderRadius:10, color:"#fff", fontSize:14, cursor:"pointer", fontFamily:"inherit" }}>Cancelar</button>
          <button onClick={saveSettings} style={{ flex:2, padding:12, background:"linear-gradient(135deg,#4F6BED,#9B59B6)",
            border:"none", borderRadius:10, color:"#fff", fontSize:14, fontWeight:700, cursor:"pointer", fontFamily:"inherit" }}>Salvar</button>
        </div>
      </div>
    </div>
  )}

  {/* ══ MODAL: Editar Roteiro ══ */}
  {editItinerary && (
    <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.75)", zIndex:200,
      display:"flex", alignItems:"flex-end", justifyContent:"center" }}
      onClick={e=>e.target===e.currentTarget&&setEditItinerary(false)}>
      <div style={{ background:"#141929", borderRadius:"18px 18px 0 0", padding:20,
        width:"100%", maxWidth:480, maxHeight:"88vh", overflowY:"auto" }}>
        <div style={{ fontSize:15, fontWeight:800, marginBottom:16 }}>🗓️ Editar Roteiro</div>
        {itin.map((day,di)=>(
          <div key={di} style={{ marginBottom:16, paddingBottom:14, borderBottom:"1px solid rgba(255,255,255,0.06)" }}>
            <div style={{ fontSize:12, fontWeight:700, color:"#7F9FFF", marginBottom:8 }}>{day.date}</div>
            {day.activities.map((a,ai)=>(
              <div key={ai} style={{ display:"flex", alignItems:"center", gap:7, marginBottom:6 }}>
                <div style={{ flex:1, fontSize:12, background:"#0B0F1A", borderRadius:8,
                  padding:"7px 10px", color:"#F0F4FF", opacity:0.85 }}>{a}</div>
                <button onClick={()=>removeAct(di,ai)} style={{ background:"rgba(255,68,68,0.12)",
                  border:"none", borderRadius:7, color:"#FF4444", fontSize:14,
                  cursor:"pointer", padding:"6px 10px", flexShrink:0 }}>×</button>
              </div>
            ))}
            <div style={{ display:"flex", gap:7, marginTop:6 }}>
              <input value={newActivity[di]||""} onChange={e=>setNewActivity(p=>({...p,[di]:e.target.value}))}
                placeholder="+ Nova atividade..."
                onKeyDown={e=>e.key==="Enter"&&addAct(di)}
                style={{ ...inp, fontSize:12, padding:"8px 10px" }} />
              <button onClick={()=>addAct(di)} style={{ padding:"8px 14px",
                background:"rgba(79,107,237,0.25)", border:"1px solid rgba(79,107,237,0.4)",
                borderRadius:8, color:"#8FA4FF", fontSize:16, cursor:"pointer", flexShrink:0 }}>+</button>
            </div>
          </div>
        ))}
        <div style={{ display:"flex", gap:10, marginTop:4 }}>
          <button onClick={()=>setEditItinerary(false)} style={{ flex:1, padding:12, background:"rgba(255,255,255,0.07)",
            border:"none", borderRadius:10, color:"#fff", fontSize:14, cursor:"pointer", fontFamily:"inherit" }}>Cancelar</button>
          <button onClick={saveItin} style={{ flex:2, padding:12, background:"linear-gradient(135deg,#4F6BED,#9B59B6)",
            border:"none", borderRadius:10, color:"#fff", fontSize:14, fontWeight:700, cursor:"pointer", fontFamily:"inherit" }}>Salvar Roteiro</button>
        </div>
      </div>
    </div>
  )}

  {/* TOAST */}
  {toast && (
    <div style={{ position:"fixed", top:18, left:"50%", transform:"translateX(-50%)",
      background:"#4FE89B", color:"#000", padding:"10px 22px", borderRadius:99,
      fontSize:13, fontWeight:700, zIndex:999,
      boxShadow:"0 4px 24px rgba(79,232,155,0.4)", whiteSpace:"nowrap" }}>
      {toast}
    </div>
  )}

  {/* BOTTOM NAV */}
  <div style={{ position:"fixed", bottom:0, left:"50%", transform:"translateX(-50%)",
    width:"100%", maxWidth:480, background:"#0D1120", borderTop:"1px solid rgba(255,255,255,0.06)", display:"flex" }}>
    {tabs.map(t=>(
      <button key={t.id} onClick={()=>setTab(t.id)} style={{ flex:1, padding:"11px 0 13px", background:"none",
        border:"none", cursor:"pointer", display:"flex", flexDirection:"column",
        alignItems:"center", gap:2, opacity:tab===t.id?1:0.36, transition:"opacity .2s" }}>
        <span style={{ fontSize:17 }}>{t.icon}</span>
        <span style={{ fontSize:9, color:tab===t.id?"#7F9FFF":"#888", fontWeight:tab===t.id?700:400 }}>{t.label}</span>
      </button>
    ))}
  </div>
</div>
