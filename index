}

// ══════════════════════════════════════════
//  FORMATTERS
// ══════════════════════════════════════════
const fUSD = v => `US$ ${Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}`;
const fBRL = v => `R$ ${Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}`;
const fCLP = v => `$ ${Math.round(Number(v)).toLocaleString('pt-BR')} CLP`;

function toUSD(amount, currency) {
  const n = Number(amount);
  if (currency === 'USD') return n;
  if (currency === 'BRL') return n / S.usdRate;
  if (currency === 'CLP') return (n * S.clpRate) / S.usdRate;
  return n;
}

// ══════════════════════════════════════════
//  COMPUTED TOTALS
// ══════════════════════════════════════════
function totals() {
  const spent = S.expenses.reduce((s,e) => s + e.usd, 0);
  const left  = S.nomadUSD - spent;
  const pct   = Math.min((spent / (S.nomadUSD||1)) * 100, 100);
  return { spent, left, pct };
}

// ══════════════════════════════════════════
//  RENDER HEADER
// ══════════════════════════════════════════
function renderHeader() {
  const { spent, left, pct } = totals();
  const color = pct > 90 ? '#FF4444' : pct > 70 ? '#FFAA00' : '#4FE89B';

  document.getElementById('hd-left-usd').textContent  = fUSD(Math.max(left,0));
  document.getElementById('hd-left-usd').style.color  = left >= 0 ? '#4FE89B' : '#FF4444';
  document.getElementById('hd-spent-usd').textContent = fUSD(spent);
  document.getElementById('hd-total-usd').textContent = 'de ' + fUSD(S.nomadUSD);
  document.getElementById('hd-bar').style.width        = pct + '%';
  document.getElementById('hd-bar').style.background   = color;
  document.getElementById('hd-pct').textContent        = pct.toFixed(1) + '% usado';

  const saldoEl = document.getElementById('hd-saldo');
  if (left >= 0) { saldoEl.textContent = 'Saldo: ' + fUSD(left); saldoEl.style.color = '#4FE89B'; }
  else           { saldoEl.textContent = 'Excedeu: ' + fUSD(Math.abs(left)); saldoEl.style.color = '#FF4444'; }

  const leftBRL = Math.max(left,0) * S.usdRate;
  const leftCLP = leftBRL / S.clpRate;
  document.getElementById('hd-brl').textContent      = fBRL(leftBRL);
  document.getElementById('hd-brl-gasto').textContent= 'gasto: ' + fBRL(spent * S.usdRate);
  document.getElementById('hd-clp').textContent      = fCLP(leftCLP);
  document.getElementById('hd-clp-gasto').textContent= 'gasto: ' + fCLP(spent * S.usdRate / S.clpRate);
}

// ══════════════════════════════════════════
//  RENDER CATEGORIES
// ══════════════════════════════════════════
function renderCategories() {
  const list = document.getElementById('cat-list');
  list.innerHTML = '';
  S.categories.forEach(cat => {
    const spent = S.expenses.filter(e => e.category === cat.category).reduce((s,e) => s+e.usd, 0);
    const p = cat.budgeted > 0 ? Math.min((spent/cat.budgeted)*100,100) : 0;
    const bar = cat.budgeted > 0
      ? `<div style="background:rgba(255,255,255,.07);border-radius:99px;height:4px;margin-top:7px">
           <div style="height:100%;width:${p}%;background:${cat.color};border-radius:99px;transition:width .4s"></div>
         </div>` : '';
    const prevSub = cat.budgeted > 0
      ? `${fUSD(cat.budgeted)} <span style="opacity:.6">· ${fBRL(cat.budgeted*S.usdRate)}</span>` : '—';
    list.innerHTML += `
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div style="display:flex;align-items:center;gap:8px">
            <span style="font-size:19px">${cat.icon}</span>
            <div>
              <div style="font-size:13px;font-weight:600">${cat.category}</div>
              <div style="font-size:10px;opacity:.4">Prev: ${prevSub}</div>
            </div>
          </div>
          <div style="text-align:right">
            <div style="font-size:14px;font-weight:700;color:${cat.color}">${fUSD(spent)}</div>
            <div style="font-size:10px;opacity:.4">${fBRL(spent*S.usdRate)}</div>
            ${cat.budgeted>0 ? `<div style="font-size:9px;opacity:.38">${p.toFixed(0)}% do prev.</div>`:''}
          </div>
        </div>${bar}
      </div>`;
  });
}

// ══════════════════════════════════════════
//  RENDER EXPENSES
// ══════════════════════════════════════════
function renderExpenses() {
  const list  = document.getElementById('expense-list');
  const empty = document.getElementById('expense-empty');
  list.innerHTML = '';
  if (S.expenses.length === 0) { empty.style.display='block'; return; }
  empty.style.display = 'none';
  S.expenses.forEach(exp => {
    const cat = S.categories.find(c => c.category === exp.category) || {};
    const color = cat.color || '#4F6BED';
    const icon  = cat.icon  || '💸';
    const noteHtml = exp.note ? `<div style="font-size:10px;opacity:.32;font-style:italic">${exp.note}</div>` : '';
    const origHtml = exp.currency === 'USD' ? `<div style="font-size:9px;opacity:.42">${fUSD(exp.amount)}</div>`
                   : exp.currency === 'CLP' ? `<div style="font-size:9px;opacity:.42">${fCLP(exp.amount)}</div>`
                   : '';
    list.innerHTML += `
      <div class="expense-item" style="border-left:3px solid ${color}">
        <span style="font-size:20px;flex-shrink:0">${icon}</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${exp.desc}</div>
          <div style="font-size:10px;opacity:.42">${exp.category} · ${exp.date}/07</div>
          ${noteHtml}
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-size:14px;font-weight:800;color:${color}">${fUSD(exp.usd)}</div>
          <div style="font-size:10px;opacity:.45">${fBRL(exp.usd*S.usdRate)}</div>
          <div style="font-size:9px;opacity:.3">${fCLP(exp.usd*S.usdRate/S.clpRate)}</div>
          ${origHtml}
        </div>
        <button onclick="deleteExpense(${exp.id})" style="background:none;border:none;color:#FF4444;font-size:20px;cursor:pointer;padding-left:4px;flex-shrink:0;line-height:1">×</button>
      </div>`;
  });
}

function deleteExpense(id) {
  S.expenses = S.expenses.filter(e => e.id !== id);
  save(); renderAll(); showToast('Removido 🗑️');
}

// ══════════════════════════════════════════
//  RENDER ITINERARY
// ══════════════════════════════════════════
function renderItin() {
  const list = document.getElementById('itin-list');
  list.innerHTML = '';
  S.itinerary.forEach(day => {
    const key   = day.date.slice(4);
    const spent = S.expenses.filter(e => e.date === key).reduce((s,e) => s+e.usd, 0);
    const spentHtml = spent > 0
      ? `<div style="font-size:13px;font-weight:700;color:#4FE89B">${fUSD(spent)}</div>
         <div style="font-size:10px;opacity:.38">${fBRL(spent*S.usdRate)}</div>`
      : `<div style="font-size:13px;font-weight:700;color:#fff;opacity:.15">${fUSD(0)}</div>`;
    const acts = day.activities.map((a,j) =>
      `<div style="font-size:12px;padding:4px 0;display:flex;align-items:center;gap:7px;${j<day.activities.length-1?'border-bottom:1px solid rgba(255,255,255,.04)':''}">
        <span style="opacity:.28;font-size:9px">●</span> ${a}
       </div>`).join('');
    list.innerHTML += `
      <div class="itin-day">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
          <div>
            <div style="font-size:13px;font-weight:700;color:#7F9FFF">${day.date}</div>
            <div style="font-size:10px;opacity:.4">${day.label}</div>
          </div>
          <div style="text-align:right">${spentHtml}</div>
        </div>${acts}
      </div>`;
  });
}

// ══════════════════════════════════════════
//  RENDER TIPS
// ══════════════════════════════════════════
function renderTips() {
  const list = document.getElementById('tips-list');
  list.innerHTML = '';
  S.tips.forEach(tip => {
    list.innerHTML += `
      <div class="tip-card">
        <div style="display:flex;align-items:center;gap:9px;margin-bottom:7px">
          <span style="font-size:22px">${tip.icon}</span>
          <div style="font-size:13px;font-weight:700">${tip.title}</div>
        </div>
        <div style="font-size:12px;line-height:1.68;opacity:.7">${tip.text}</div>
      </div>`;
  });
}

// ══════════════════════════════════════════
//  RENDER CONFIG
// ══════════════════════════════════════════
function renderConfig() {
  document.getElementById('cfg-nomad').value = S.nomadUSD;
  document.getElementById('cfg-usd').value   = S.usdRate;
  document.getElementById('cfg-clp').value   = S.clpRate;
  cfgConvert();

  const { spent, left } = totals();
  document.getElementById('cfg-summary').innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05)">
      <div style="font-size:12px;opacity:.55">Nomad disponível</div>
      <div style="text-align:right"><div style="font-size:13px;font-weight:700">${fUSD(Math.max(left,0))}</div><div style="font-size:9px;opacity:.38">${fBRL(Math.max(left,0)*S.usdRate)}</div></div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05)">
      <div style="font-size:12px;opacity:.55">Total gasto</div>
      <div style="text-align:right"><div style="font-size:13px;font-weight:700">${fUSD(spent)}</div><div style="font-size:9px;opacity:.38">${fBRL(spent*S.usdRate)}</div></div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05)">
      <div style="font-size:12px;opacity:.55">Taxa: US$ 1 =</div>
      <div style="font-size:13px;font-weight:700">${fBRL(S.usdRate)}</div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0">
      <div style="font-size:12px;opacity:.55">Taxa: $ 1 CLP =</div>
      <div style="font-size:13px;font-weight:700">R$ ${S.clpRate}</div>
    </div>`;
}

function cfgConvert() {
  const nomad = Number(document.getElementById('cfg-nomad').value) || 0;
  const usd   = Number(document.getElementById('cfg-usd').value)   || S.usdRate;
  const clp   = Number(document.getElementById('cfg-clp').value)   || S.clpRate;
  document.getElementById('cfg-nomad-brl').textContent = fBRL(nomad * usd);
  document.getElementById('cfg-nomad-clp').textContent = fCLP(nomad * usd / clp);
}

function saveConfig() {
  S.nomadUSD = Number(document.getElementById('cfg-nomad').value) || S.nomadUSD;
  S.usdRate  = Number(document.getElementById('cfg-usd').value)   || S.usdRate;
  S.clpRate  = Number(document.getElementById('cfg-clp').value)   || S.clpRate;
  save(); renderAll(); showToast('Configurações salvas ✅');
}

// ══════════════════════════════════════════
//  ADD EXPENSE
// ══════════════════════════════════════════
function populateForm() {
  const catSel = document.getElementById('f-category');
  catSel.innerHTML = '';
  S.categories.forEach(c => { const o=document.createElement('option'); o.value=c.category; o.textContent=c.category; catSel.appendChild(o); });

  const dateSel = document.getElementById('f-date');
  dateSel.innerHTML = '';
  S.itinerary.forEach(d => { const o=document.createElement('option'); o.value=d.date.slice(4); o.textContent=d.date; dateSel.appendChild(o); });
  if (dateSel.options.length > 1) dateSel.selectedIndex = 1; // default dia 2
}

function toggleForm() {
  const form = document.getElementById('expense-form');
  const btn  = document.getElementById('add-btn');
  const open = form.style.display === 'block';
  form.style.display = open ? 'none' : 'block';
  btn.innerHTML = open
    ? '<span style="font-size:20px">+</span> Adicionar Gasto'
    : '<span style="font-size:20px">−</span> Cancelar';
  btn.style.background = open ? 'linear-gradient(135deg,#4F6BED,#9B59B6)' : 'rgba(255,255,255,.07)';
  if (!open) { document.getElementById('f-desc').value=''; document.getElementById('f-amount').value=''; document.getElementById('f-note').value=''; document.getElementById('expense-preview').style.display='none'; }
}

function updatePreview() {
  const amount = Number(document.getElementById('f-amount').value);
  const currency = document.getElementById('f-currency').value;
  const prev = document.getElementById('expense-preview');
  if (!amount) { prev.style.display='none'; return; }
  const usd = toUSD(amount, currency);
  document.getElementById('prev-usd').textContent = fUSD(usd);
  document.getElementById('prev-brl-clp').textContent = fBRL(usd*S.usdRate) + ' · ' + fCLP(usd*S.usdRate/S.clpRate);
  prev.style.display = 'block';
}

function addExpense() {
  const desc     = document.getElementById('f-desc').value.trim();
  const amount   = Number(document.getElementById('f-amount').value);
  const currency = document.getElementById('f-currency').value;
  const category = document.getElementById('f-category').value;
  const date     = document.getElementById('f-date').value;
  const note     = document.getElementById('f-note').value.trim();
  if (!desc || !amount) { showToast('Preencha descrição e valor ⚠️'); return; }
  const usd = toUSD(amount, currency);
  S.expenses.unshift({ id: Date.now(), desc, amount, currency, category, date, note, usd });
  save(); renderAll(); toggleForm(); showToast('Gasto adicionado! ✅');
}

function clearExpenses() {
  if (!confirm('Apagar todos os gastos lançados? Isso não pode ser desfeito.')) return;
  S.expenses = []; save(); renderAll(); showToast('Gastos apagados 🗑️');
}

// ══════════════════════════════════════════
//  MODAL SETTINGS (header button)
// ══════════════════════════════════════════
function openSettings() {
  document.getElementById('ms-nomad').value = S.nomadUSD;
  document.getElementById('ms-usd').value   = S.usdRate;
  document.getElementById('ms-clp').value   = S.clpRate;
  msConvert();
  document.getElementById('modal-settings').classList.add('open');
}
function closeSettings() { document.getElementById('modal-settings').classList.remove('open'); }
function saveSettings() {
  S.nomadUSD = Number(document.getElementById('ms-nomad').value) || S.nomadUSD;
  S.usdRate  = Number(document.getElementById('ms-usd').value)   || S.usdRate;
  S.clpRate  = Number(document.getElementById('ms-clp').value)   || S.clpRate;
  save(); renderAll(); closeSettings(); showToast('Configurações salvas ✅');
}
function msConvert() {
  const nomad = Number(document.getElementById('ms-nomad').value) || 0;
  const usd   = Number(document.getElementById('ms-usd').value)   || S.usdRate;
  const clp   = Number(document.getElementById('ms-clp').value)   || S.clpRate;
  const p = document.getElementById('ms-preview');
  p.textContent = nomad > 0 ? `= ${fBRL(nomad*usd)} · ${fCLP(nomad*usd/clp)}` : '';
}

// ══════════════════════════════════════════
//  MODAL ITINERARY
// ══════════════════════════════════════════
let itinDraft = [];

function openItin() {
  itinDraft = JSON.parse(JSON.stringify(S.itinerary));
  renderItinEdit();
  document.getElementById('modal-itin').classList.add('open');
}
function closeItin() { document.getElementById('modal-itin').classList.remove('open'); }
function saveItin() {
  S.itinerary = JSON.parse(JSON.stringify(itinDraft));
  save(); renderAll(); closeItin(); showToast('Roteiro atualizado ✅');
}

function renderItinEdit() {
  const list = document.getElementById('itin-edit-list');
  list.innerHTML = '';
  itinDraft.forEach((day, di) => {
    const acts = day.activities.map((a,ai) => `
      <div style="display:flex;align-items:center;gap:7px;margin-bottom:6px">
        <div style="flex:1;font-size:12px;background:#0B0F1A;border-radius:8px;padding:7px 10px;color:#F0F4FF;opacity:.85">${a}</div>
        <button onclick="removeAct(${di},${ai})" style="background:rgba(255,68,68,.12);border:none;border-radius:7px;color:#FF4444;font-size:14px;cursor:pointer;padding:6px 10px;flex-shrink:0">×</button>
      </div>`).join('');
    list.innerHTML += `
      <div style="margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.06)">
        <div style="font-size:12px;font-weight:700;color:#7F9FFF;margin-bottom:8px">${day.date}</div>
        ${acts}
        <div style="display:flex;gap:7px;margin-top:6px">
          <input id="new-act-${di}" class="inp" placeholder="+ Nova atividade..."
            style="font-size:12px;padding:8px 10px"
            onkeydown="if(event.key==='Enter')addAct(${di})" />
          <button onclick="addAct(${di})" style="padding:8px 14px;background:rgba(79,107,237,.25);border:1px solid rgba(79,107,237,.4);border-radius:8px;color:#8FA4FF;font-size:16px;cursor:pointer;flex-shrink:0">+</button>
        </div>
      </div>`;
  });
}

function addAct(di) {
  const inp = document.getElementById(`new-act-${di}`);
  const v = inp.value.trim();
  if (!v) return;
  itinDraft[di].activities.push(v);
  inp.value = '';
  renderItinEdit();
}
function removeAct(di, ai) {
  itinDraft[di].activities.splice(ai, 1);
  renderItinEdit();
}

// ══════════════════════════════════════════
//  TABS
// ══════════════════════════════════════════
function setTab(name, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'config') renderConfig();
}

// ══════════════════════════════════════════
//  TOAST
// ══════════════════════════════════════════
let toastTimer;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.style.display = 'block';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.style.display='none', 2500);
}

// ══════════════════════════════════════════
//  RENDER ALL
// ══════════════════════════════════════════
function renderAll() {
  renderHeader();
  renderCategories();
  renderExpenses();
  renderItin();
  renderTips();
}

// ── INIT ──
populateForm();
renderAll();
</script>

